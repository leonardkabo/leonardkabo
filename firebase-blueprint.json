{
  "entities": {
    "SiteSettings": {
      "title": "Site Settings",
      "description": "Global settings for the website",
      "type": "object",
      "properties": {
        "siteName": { "type": "string", "description": "The name of the site displayed in the logo and title" },
        "siteTitle": { "type": "string", "description": "The main title or tagline of the site" },
        "contactEmail": { "type": "string", "format": "email", "description": "Primary contact email" },
        "socialLinks": {
          "type": "object",
          "properties": {
            "linkedin": { "type": "string" },
            "twitter": { "type": "string" },
            "facebook": { "type": "string" },
            "whatsapp": { "type": "string" }
          }
        },
        "logoText": { "type": "string", "description": "Text to display next to the logo" },
        "successMessages": {
          "type": "object",
          "properties": {
            "contact": { "type": "string", "description": "Success message for contact form" },
            "appointment": { "type": "string", "description": "Success message for appointment form" },
            "quote": { "type": "string", "description": "Success message for quote form" }
          }
        },
        "countdown": {
          "type": "object",
          "properties": {
            "active": { "type": "boolean" },
            "targetDate": { "type": "string", "description": "ISO 8601 date string" },
            "message": { "type": "string" },
            "title": { "type": "string" }
          }
        }
      },
      "required": ["siteName", "siteTitle", "contactEmail"]
    },
    "HeroSection": {
      "title": "Hero Section",
      "description": "Content for the hero section of the homepage",
      "type": "object",
      "properties": {
        "badge": { "type": "string", "description": "Small text badge above the main title" },
        "title": { "type": "string", "description": "Main heading of the hero section" },
        "subtitle": { "type": "string", "description": "Bolded part of the title" },
        "description": { "type": "string", "description": "Main paragraph text" },
        "ctaText": { "type": "string", "description": "Text for the primary call to action button" },
        "ctaLink": { "type": "string", "description": "Link for the primary call to action button" },
        "secondaryCtaText": { "type": "string", "description": "Text for the secondary call to action button" },
        "secondaryCtaLink": { "type": "string", "description": "Link for the secondary call to action button" },
        "profileImage": { "type": "string", "description": "URL of the profile image" },
        "stats": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "value": { "type": "string" },
              "label": { "type": "string" },
              "sublabel": { "type": "string" },
              "color": { "type": "string", "enum": ["blue", "emerald", "amber", "purple"] }
            }
          }
        }
      }
    },
    "Service": {
      "title": "Service",
      "description": "A service offered by the business",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "slug": { "type": "string" },
        "tagline": { "type": "string" },
        "shortDesc": { "type": "string" },
        "thumbnail": { "type": "string" },
        "categoryId": { "type": "string" },
        "priority": { "type": "number" },
        "promoPrice": { "type": "number", "description": "Optional promotional price" },
        "isPromoActive": { "type": "boolean", "description": "Whether the promotion is currently active" },
        "promoStartDate": { "type": "string", "description": "Start date of the promotion (YYYY-MM-DD)" },
        "promoEndDate": { "type": "string", "description": "End date of the promotion (YYYY-MM-DD)" }
      },
      "required": ["title", "slug", "categoryId"]
    },
    "PortfolioItem": {
      "title": "Portfolio Item",
      "description": "A project in the portfolio",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "category": { "type": "string" },
        "image": { "type": "string" },
        "description": { "type": "string" },
        "technologies": { "type": "array", "items": { "type": "string" } }
      },
      "required": ["title", "category", "image"]
    },
    "NewsItem": {
      "title": "News Item",
      "description": "An article in the news/blog section",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "body": { "type": "string" },
        "author": { "type": "string" },
        "readTime": { "type": "string" },
        "createdAt": { "type": "number" },
        "image": { "type": "string" }
      },
      "required": ["title", "body", "createdAt"]
    },
    "Appointment": {
      "title": "Appointment",
      "description": "An appointment request",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "phone": { "type": "string" },
        "date": { "type": "string" },
        "time": { "type": "string" },
        "service": { "type": "string" },
        "message": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "confirmed", "cancelled"] },
        "createdAt": { "type": "number" }
      },
      "required": ["name", "email", "phone", "date", "time", "service", "status", "createdAt"]
    },
    "Quote": {
      "title": "Quote",
      "description": "A quote request",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "company": { "type": "string" },
        "service": { "type": "string" },
        "budget": { "type": "string" },
        "description": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "responded"] },
        "createdAt": { "type": "number" }
      },
      "required": ["name", "email", "service", "description", "status", "createdAt"]
    },
    "Contact": {
      "title": "Contact",
      "description": "A contact message",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "subject": { "type": "string" },
        "message": { "type": "string" },
        "status": { "type": "string", "enum": ["unread", "read"] },
        "createdAt": { "type": "number" }
      },
      "required": ["name", "email", "subject", "message", "status", "createdAt"]
    },
    "VotingEvent": {
      "title": "Voting Event",
      "description": "Configuration and candidates for a voting event",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "description": { "type": "string" },
        "rules": { "type": "string" },
        "active": { "type": "boolean" },
        "maxVotes": { "type": "number", "description": "Number of candidates a user can select" },
        "candidates": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "id": { "type": "string" },
              "name": { "type": "string" },
              "description": { "type": "string" },
              "imageUrl": { "type": "string" },
              "voteCount": { "type": "number" }
            }
          }
        }
      },
      "required": ["title", "active", "maxVotes", "candidates"]
    },
    "Visitor": {
      "title": "Visitor session",
      "description": "Information about a current visitor session for real-time tracking",
      "type": "object",
      "properties": {
        "lastSeen": { "type": "number", "description": "Timestamp of the last heartbeat" },
        "path": { "type": "string", "description": "Current path the user is visiting" },
        "device": { "type": "string", "description": "Simple device/browser info" }
      },
      "required": ["lastSeen"]
    },
    "DailyStats": {
      "title": "Daily Stats",
      "description": "Aggregated stats for a specific day",
      "type": "object",
      "properties": {
        "visits": { "type": "number", "description": "Total unique session visits for the day" },
        "date": { "type": "string", "description": "YYYY-MM-DD" }
      },
      "required": ["visits", "date"]
    },
    "AdminUser": {
      "title": "Admin User",
      "description": "A user with access to the admin dashboard",
      "type": "object",
      "properties": {
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "role": { "type": "string", "enum": ["superadmin", "moderator"] },
        "isAdmin": { "type": "boolean", "description": "True for superadmins who can manage other users" },
        "permissions": { 
          "type": "array", 
          "items": { "type": "string" },
          "description": "List of tabs/actions the user can access: voting, news, portfolio, services, analytics, appointments, contacts, settings"
        },
        "createdAt": { "type": "number" }
      },
      "required": ["email", "role", "permissions"]
    }
  },
  "firestore": {
    "/settings/site": { "schema": "SiteSettings", "description": "Global site configuration" },
    "/voting/active": { "schema": "VotingEvent", "description": "The currently active voting event" },
    "/sections/hero": { "schema": "HeroSection", "description": "Hero section content" },
    "/services/{serviceId}": { "schema": "Service", "description": "List of services" },
    "/portfolio/{itemId}": { "schema": "PortfolioItem", "description": "List of portfolio items" },
    "/news/{newsId}": { "schema": "NewsItem", "description": "List of news articles" },
    "/appointments/{appointmentId}": { "schema": "Appointment", "description": "List of appointment requests" },
    "/quotes/{quoteId}": { "schema": "Quote", "description": "List of quote requests" },
    "/contacts/{contactId}": { "schema": "Contact", "description": "List of contact messages" },
    "/users/{userEmail}": { "schema": "AdminUser", "description": "List of administrative users keyed by email" },
    "/analytics/realtime/sessions/{sessionId}": { "schema": "Visitor", "description": "Real-time active sessions" },
    "/analytics/history/days/{date}": { "schema": "DailyStats", "description": "Historical visit statistics" }
  }
}
