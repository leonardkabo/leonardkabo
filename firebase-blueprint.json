{
  "entities": {
    "SiteSettings": {
      "title": "Site Settings",
      "description": "Global settings for the website",
      "type": "object",
      "properties": {
        "siteName": { "type": "string", "description": "The name of the site displayed in the logo and title" },
        "siteTitle": { "type": "string", "description": "The main title or tagline of the site" },
        "contactEmail": { "type": "string", "format": "email", "description": "Primary contact email" },
        "socialLinks": {
          "type": "object",
          "properties": {
            "linkedin": { "type": "string" },
            "twitter": { "type": "string" },
            "facebook": { "type": "string" },
            "whatsapp": { "type": "string" }
          }
        },
        "logoText": { "type": "string", "description": "Text to display next to the logo" },
        "successMessages": {
          "type": "object",
          "properties": {
            "contact": { "type": "string", "description": "Success message for contact form" },
            "appointment": { "type": "string", "description": "Success message for appointment form" },
            "quote": { "type": "string", "description": "Success message for quote form" }
          }
        }
      },
      "required": ["siteName", "siteTitle", "contactEmail"]
    },
    "HeroSection": {
      "title": "Hero Section",
      "description": "Content for the hero section of the homepage",
      "type": "object",
      "properties": {
        "badge": { "type": "string", "description": "Small text badge above the main title" },
        "title": { "type": "string", "description": "Main heading of the hero section" },
        "subtitle": { "type": "string", "description": "Bolded part of the title" },
        "description": { "type": "string", "description": "Main paragraph text" },
        "ctaText": { "type": "string", "description": "Text for the primary call to action button" },
        "ctaLink": { "type": "string", "description": "Link for the primary call to action button" },
        "secondaryCtaText": { "type": "string", "description": "Text for the secondary call to action button" },
        "secondaryCtaLink": { "type": "string", "description": "Link for the secondary call to action button" },
        "profileImage": { "type": "string", "description": "URL of the profile image" },
        "stats": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "value": { "type": "string" },
              "label": { "type": "string" },
              "sublabel": { "type": "string" },
              "color": { "type": "string", "enum": ["blue", "emerald", "amber", "purple"] }
            }
          }
        }
      }
    },
    "Service": {
      "title": "Service",
      "description": "A service offered by the business",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "slug": { "type": "string" },
        "tagline": { "type": "string" },
        "shortDesc": { "type": "string" },
        "thumbnail": { "type": "string" },
        "categoryId": { "type": "string" },
        "priority": { "type": "number" },
        "promoPrice": { "type": "number", "description": "Optional promotional price" },
        "isPromoActive": { "type": "boolean", "description": "Whether the promotion is currently active" },
        "promoStartDate": { "type": "string", "description": "Start date of the promotion (YYYY-MM-DD)" },
        "promoEndDate": { "type": "string", "description": "End date of the promotion (YYYY-MM-DD)" }
      },
      "required": ["title", "slug", "categoryId"]
    },
    "PortfolioItem": {
      "title": "Portfolio Item",
      "description": "A project in the portfolio",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "category": { "type": "string" },
        "image": { "type": "string" },
        "description": { "type": "string" },
        "technologies": { "type": "array", "items": { "type": "string" } }
      },
      "required": ["title", "category", "image"]
    },
    "NewsItem": {
      "title": "News Item",
      "description": "An article in the news/blog section",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "body": { "type": "string" },
        "author": { "type": "string" },
        "readTime": { "type": "string" },
        "createdAt": { "type": "number" },
        "image": { "type": "string" }
      },
      "required": ["title", "body", "createdAt"]
    },
    "Appointment": {
      "title": "Appointment",
      "description": "An appointment request",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "phone": { "type": "string" },
        "date": { "type": "string" },
        "time": { "type": "string" },
        "service": { "type": "string" },
        "message": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "confirmed", "cancelled"] },
        "createdAt": { "type": "number" }
      },
      "required": ["name", "email", "phone", "date", "time", "service", "status", "createdAt"]
    },
    "Quote": {
      "title": "Quote",
      "description": "A quote request",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "company": { "type": "string" },
        "service": { "type": "string" },
        "budget": { "type": "string" },
        "description": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "responded"] },
        "createdAt": { "type": "number" }
      },
      "required": ["name", "email", "service", "description", "status", "createdAt"]
    },
    "Contact": {
      "title": "Contact",
      "description": "A contact message",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "subject": { "type": "string" },
        "message": { "type": "string" },
        "status": { "type": "string", "enum": ["unread", "read"] },
        "createdAt": { "type": "number" }
      },
      "required": ["name", "email", "subject", "message", "status", "createdAt"]
    }
  },
  "firestore": {
    "/settings/site": { "schema": "SiteSettings", "description": "Global site configuration" },
    "/sections/hero": { "schema": "HeroSection", "description": "Hero section content" },
    "/services/{serviceId}": { "schema": "Service", "description": "List of services" },
    "/portfolio/{itemId}": { "schema": "PortfolioItem", "description": "List of portfolio items" },
    "/news/{newsId}": { "schema": "NewsItem", "description": "List of news articles" },
    "/appointments/{appointmentId}": { "schema": "Appointment", "description": "List of appointment requests" },
    "/quotes/{quoteId}": { "schema": "Quote", "description": "List of quote requests" },
    "/contacts/{contactId}": { "schema": "Contact", "description": "List of contact messages" }
  }
}
