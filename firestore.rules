rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: settings
    // Document ID: site
    // Fields:
    //   - siteName: string (required)
    //   - siteTitle: string (required)
    //   - contactEmail: string (required, email)
    //   - socialLinks: map (optional)
    //   - logoText: string (optional)
    //   - logoImage: string (optional)
    //   - successMessages: map (optional)
    //   - countdown: map (optional)
    //     - active: boolean
    //     - targetDate: string (ISO)
    //     - message: string
    //     - title: string
    //
    // Collection: sections
    // Document ID: hero
    // Fields:
    //   - badge: string
    //   - title: string
    //   - subtitle: string
    //   - description: string
    //   - ctaText: string
    //   - ctaLink: string
    //   - secondaryCtaText: string
    //   - secondaryCtaLink: string
    //   - profileImage: string
    //   - stats: list of maps
    //
    // Collection: services
    // Document ID: auto-generated
    // Fields:
    //   - title: string (required)
    //   - slug: string (required)
    //   - tagline: string
    //   - shortDesc: string
    //   - thumbnail: string
    //   - categoryId: string (required)
    //   - priority: number
    //
    // Collection: portfolio
    // Document ID: auto-generated
    // Fields:
    //   - title: string (required)
    //   - category: string (required)
    //   - image: string (required)
    //   - description: string
    //   - technologies: list of strings
    //
    // Collection: appointments
    // Document ID: auto-generated
    // Fields:
    //   - name: string (required)
    //   - email: string (required, email)
    //   - phone: string (required)
    //   - date: string (required)
    //   - time: string (required)
    //   - service: string (required)
    //   - message: string (optional)
    //   - status: string (required, enum: ['pending', 'confirmed', 'cancelled'])
    //   - createdAt: timestamp (required)
    //
    // Collection: quotes
    // Document ID: auto-generated
    // Fields:
    //   - name: string (required)
    //   - email: string (required, email)
    //   - company: string (optional)
    //   - service: string (required)
    //   - budget: string (optional)
    //   - description: string (required)
    //   - status: string (required, enum: ['pending', 'responded'])
    //   - createdAt: number (required)
    //
    // Collection: contacts
    // Document ID: auto-generated
    // Fields:
    //   - name: string (required)
    //   - email: string (required, email)
    //   - subject: string (required)
    //   - message: string (required)
    //   - status: string (required, enum: ['unread', 'read'])
    //   - createdAt: number (required)
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }

    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.token.email.lower())).data;
    }

    function isSuperAdmin() {
      return isAuthenticated() && (
        request.auth.token.email.lower() == "leonardkabo32@gmail.com" ||
        (exists(/databases/$(database)/documents/users/$(request.auth.token.email.lower())) && 
         (getUserData().role == "superadmin" || getUserData().isAdmin == true))
      );
    }

    function hasPermission(permission) {
      return isAuthenticated() && (
        isSuperAdmin() ||
        (exists(/databases/$(database)/documents/users/$(request.auth.token.email.lower())) && (
          "all" in getUserData().get('permissions', []) ||
          permission in getUserData().get('permissions', [])
        ))
      );
    }

    // Default isAdmin helper kept for compatibility
    function isAdmin() {
      return isSuperAdmin();
    }

    function isValidEmail(email) {
      return email is string &&
        email.matches(".+@.+\\..+");
    }

    function isValidVoting(data) {
      return data.title is string && data.title.size() <= 500 &&
             data.description is string && data.description.size() <= 10000 &&
             data.active is bool &&
             data.candidates is list &&
             (data.get('isPaid', false) == false || (data.pricePerVote is number && data.paymentConfig is map));
    }

    // ===============================================================
    // Rules
    // ===============================================================

    // Publicly readable, admin writable
    match /settings/{docId} {
      allow read: if true;
      allow write: if hasPermission('settings');
    }

    match /sections/{docId} {
      allow read: if true;
      allow write: if hasPermission('settings');
    }

    match /services/{docId} {
      allow read: if true;
      allow write: if hasPermission('services');
    }

    match /portfolio/{docId} {
      allow read: if true;
      allow write: if hasPermission('portfolio');
    }

    match /news/{docId} {
      allow read: if true;
      allow write: if hasPermission('news');
    }

    match /voting/{docId} {
      allow read: if true;
      allow update: if (
        // Public Vote Action: Only voterCount and candidates can be updated during active vote
        (resource.data.get('active', false) == true && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['candidates', 'voterCount'])) ||
        hasPermission('voting')
      );
      allow create, delete: if hasPermission('voting');

      match /ballots/{ballotId} {
        allow read: if hasPermission('voting');
        allow create: if (
          get(/databases/$(database)/documents/voting/$(docId)).data.get('active', false) == true &&
          request.resource.data.voterName is string &&
          request.resource.data.voterPhone is string &&
          request.resource.data.candidateIds is list &&
          request.resource.data.timestamp in [request.time, null] &&
          (request.resource.data.get('isPaid', false) == false || (request.resource.data.paymentStatus == 'paid' && request.resource.data.amount > 0))
        );
        allow write: if hasPermission('voting');
      }
    }

    match /test/{docId} {
      allow read: if true;
    }

    // Publicly writable (for submissions), admin readable/writable
    match /appointments/{docId} {
      allow create: if request.resource.data.name is string &&
                      isValidEmail(request.resource.data.email) &&
                      request.resource.data.status == 'pending';
      allow read, update, delete: if hasPermission('appointments');
    }

    match /quotes/{docId} {
      allow create: if request.resource.data.name is string &&
                      isValidEmail(request.resource.data.email) &&
                      request.resource.data.status == 'pending';
      allow read, update, delete: if hasPermission('quotes');
    }

    match /contacts/{docId} {
      allow create: if request.resource.data.name is string &&
                      isValidEmail(request.resource.data.email) &&
                      request.resource.data.status == 'unread';
      allow read, update, delete: if hasPermission('contacts');
    }

    match /users/{userEmail} {
      allow read: if isAuthenticated() && (request.auth.token.email.lower() == userEmail.lower() || hasPermission('settings'));
      allow write: if isSuperAdmin();
    }

    match /analytics/realtime/sessions/{sessionId} {
      allow create, update, get: if true;
      allow read, delete: if hasPermission('audience');
    }

    match /analytics/history/days/{date} {
      allow create, update, get: if true;
      allow read, delete: if hasPermission('audience');
    }
  }
}
