rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: settings
    // Document ID: site
    // Fields:
    //   - siteName: string (required)
    //   - siteTitle: string (required)
    //   - contactEmail: string (required, email)
    //   - socialLinks: map (optional)
    //   - logoText: string (optional)
    //   - logoImage: string (optional)
    //   - successMessages: map (optional)
    //   - countdown: map (optional)
    //     - active: boolean
    //     - targetDate: string (ISO)
    //     - message: string
    //     - title: string
    //
    // Collection: sections
    // Document ID: hero
    // Fields:
    //   - badge: string
    //   - title: string
    //   - subtitle: string
    //   - description: string
    //   - ctaText: string
    //   - ctaLink: string
    //   - secondaryCtaText: string
    //   - secondaryCtaLink: string
    //   - profileImage: string
    //   - stats: list of maps
    //
    // Collection: services
    // Document ID: auto-generated
    // Fields:
    //   - title: string (required)
    //   - slug: string (required)
    //   - tagline: string
    //   - shortDesc: string
    //   - thumbnail: string
    //   - categoryId: string (required)
    //   - priority: number
    //
    // Collection: portfolio
    // Document ID: auto-generated
    // Fields:
    //   - title: string (required)
    //   - category: string (required)
    //   - image: string (required)
    //   - description: string
    //   - technologies: list of strings
    //
    // Collection: appointments
    // Document ID: auto-generated
    // Fields:
    //   - name: string (required)
    //   - email: string (required, email)
    //   - phone: string (required)
    //   - date: string (required)
    //   - time: string (required)
    //   - service: string (required)
    //   - message: string (optional)
    //   - status: string (required, enum: ['pending', 'confirmed', 'cancelled'])
    //   - createdAt: timestamp (required)
    //
    // Collection: quotes
    // Document ID: auto-generated
    // Fields:
    //   - name: string (required)
    //   - email: string (required, email)
    //   - company: string (optional)
    //   - service: string (required)
    //   - budget: string (optional)
    //   - description: string (required)
    //   - status: string (required, enum: ['pending', 'responded'])
    //   - createdAt: number (required)
    //
    // Collection: contacts
    // Document ID: auto-generated
    // Fields:
    //   - name: string (required)
    //   - email: string (required, email)
    //   - subject: string (required)
    //   - message: string (required)
    //   - status: string (required, enum: ['unread', 'read'])
    //   - createdAt: number (required)
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() &&
        (
          (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
           get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin') ||
          (request.auth.token.email == "leonardkabo32@gmail.com" && 
           (request.auth.token.email_verified == true || !('email_verified' in request.auth.token)))
        );
    }

    function isValidEmail(email) {
      return email is string &&
        email.matches(".+@.+\\..+");
    }

    function isValidVoting(data) {
      return data.title is string && data.title.size() <= 500 &&
             data.description is string && data.description.size() <= 10000 &&
             data.active is bool &&
             data.candidates is list;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    // Publicly readable, admin writable
    match /settings/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /sections/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /services/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /portfolio/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /news/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /voting/{docId} {
      allow read: if true;
      allow update: if (
        // Public Vote Action: Only voterCount and candidates can be updated during active vote
        (resource.data.active == true && request.resource.data.diff(resource.data).affectedKeys().hasAny(['candidates', 'voterCount'])) ||
        isAdmin()
      );
      allow create, delete: if isAdmin();

      match /ballots/{ballotId} {
        allow read: if isAdmin();
        allow create: if (
          get(/databases/$(database)/documents/voting/$(docId)).data.active == true &&
          request.resource.data.voterName is string &&
          request.resource.data.candidateIds is list &&
          request.resource.data.timestamp is string
        );
        allow write: if isAdmin();
      }
    }

    match /test/{docId} {
      allow read: if true;
    }

    // Publicly writable (for submissions), admin readable/writable
    match /appointments/{docId} {
      allow create: if request.resource.data.name is string &&
                      isValidEmail(request.resource.data.email) &&
                      request.resource.data.status == 'pending';
      allow read, update, delete: if isAdmin();
    }

    match /quotes/{docId} {
      allow create: if request.resource.data.name is string &&
                      isValidEmail(request.resource.data.email) &&
                      request.resource.data.status == 'pending';
      allow read, update, delete: if isAdmin();
    }

    match /contacts/{docId} {
      allow create: if request.resource.data.name is string &&
                      isValidEmail(request.resource.data.email) &&
                      request.resource.data.status == 'unread';
      allow read, update, delete: if isAdmin();
    }

    match /users/{userId} {
      allow read: if isAuthenticated() && request.auth.uid == userId;
      allow write: if isAdmin();
    }
  }
}
